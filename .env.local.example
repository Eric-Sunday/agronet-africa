# AgroNet Africa — Environment Variables
# 
# Copy this file to .env.local and update the values as needed.
# This project uses Vite, so environment variables must be prefixed with VITE_

# Backend API URL (Render deployment or local development)
# Default fallback: https://agronet-backend.onrender.com
# For local development: http://localhost:5000
VITE_API_URL=https://agronet-backend.onrender.com

# Optional: Analytics, Monitoring, or Third-party Services
# VITE_ANALYTICS_ID=your-analytics-id
# VITE_SENTRY_DSN=your-sentry-dsn
